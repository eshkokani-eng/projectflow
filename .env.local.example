# =============================================================
# FILE: .env.local.example
#
# HOW TO USE:
#   1. Copy this file → rename to: .env.local
#   2. Fill in each value below
#   3. NEVER commit .env.local to Git
#
# ON VERCEL:
#   Add each variable under:
#   Project Settings → Environment Variables
# =============================================================

# ─── SUPABASE ────────────────────────────────────────────────
# From: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── RESEND (Email Notifications) ────────────────────────────
# From: resend.com → Dashboard → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── SENDER EMAIL ─────────────────────────────────────────────
# For testing (no domain needed):
#   NOTIFY_FROM_EMAIL=ProjectFlow <onboarding@resend.dev>
# For production (verified domain in Resend):
#   NOTIFY_FROM_EMAIL=ProjectFlow <notifications@aralsane.com>
NOTIFY_FROM_EMAIL=ProjectFlow <onboarding@resend.dev>
